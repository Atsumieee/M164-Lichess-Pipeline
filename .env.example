# Copy this file to ".env" and fill in your values.
#   cp .env.example .env      (or: copy .env.example .env  on Windows)
#
# These four values are read by the app to connect to SQL Server.
# The database name itself ("LichessTournaments") is fixed in the code.

# Host where SQL Server runs. Use "localhost" if it's on this machine.
DB_SERVER=localhost

# Named instance. SQL Server Express installs as "SQLEXPRESS" by default.
DB_INSTANCE=SQLEXPRESS

# The SQL login created by db-setup.sql (NOT a Windows account).
DB_USER=lichess_app

# The password you set for that login in db-setup.sql.
DB_PASSWORD=ChangeMe_StrongPassword1
