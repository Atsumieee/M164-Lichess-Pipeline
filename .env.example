# These values are written automatically by "npm run init".
# You only need this file if you want to override the defaults.

# Host and instance name (defaults: localhost / SQLEXPRESS)
DB_SERVER=localhost
DB_INSTANCE=SQLEXPRESS

# SQL login credentials — only needed when NOT using Windows Authentication.
# Leave these out (or remove them) to use Windows Authentication instead.
DB_USER=lichess_app
DB_PASSWORD=ChangeMe_StrongPassword1
